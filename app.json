    "AUTO_READ_CMD": {
      "description": "Auto read commands: true/false",
      "required": false,
      "value": "true"
    },
    "PACKNAME": {
      "description": "Sticker pack name",
      "required": false,
      "value": "SHAVIYA-XMD V3"
    },
    "AUTHOR": {
      "description": "Sticker author name",
      "required": false,
      "value": "SHAVIYA TECH"
    },
    "ALIVE_IMG": {
      "description": "Alive command image URL",
      "required": false,
      "value": "https://i.ibb.co/C5PdQgTz/imgbb-1774247334984.jpg"
    },
    "MENU_IMG": {
      "description": "Menu image URL",
      "required": false,
      "value": "https://i.ibb.co/C5PdQgTz/imgbb-1774247334984.jpg"
    },
    "OPENAI_API_KEY": {
      "description": "OpenAI API Key (optional - for GPT commands)",
